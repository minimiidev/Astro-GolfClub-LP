---
import Heading from "../ui/Heading.astro";
import Logo from "../ui/Logo.astro";
---

<footer class="pt-10 h-dvh md:h-fit bg-accent-dark">
	<div
		class="flex flex-wrap lg:flex-nowrap justify-between items-start gap-12 md:gap-4 mb-12 container"
	>
		<article class="flex flex-col gap-4 max-w-90">
			<Logo />
			<p class="font-light text-sm!">
				A legacy of excellence since 1924. Redefining the modern golf
				experience for enthusiasts and professionals alike.
			</p>
			<div class="flex gap-4">
				<img
					src="/addressIcon.png"
					alt=""
					class="border border-white rounded-full"
				/>
				<img
					src="/mailIcon.png"
					alt=""
					class="border border-white rounded-full"
				/>
				<img
					src="/shareIcon.png"
					alt=""
					class="border border-white rounded-full"
				/>
			</div>
		</article>

		<article class="flex flex-col gap-4">
			<Heading tagName="h4" tagSize="h4">QUICK LINKS</Heading>
			<div class="gap-4 grid grid-cols-2 font-bold text-black">
				<a href="#">TOPTRACER RANGE</a>
				<a href="#">CRAZY GOLF</a>
				<a href="#">CAFE</a>
				<a href="#">EVENTS</a>
				<a href="#">GOLF LESSONS</a>
				<a href="#">CONTACT US</a>
			</div>
		</article>

		<article class="flex flex-col gap-4 max-w-90 uppercase">
			<Heading tagName="h4" tagSize="h4">CONTACT US</Heading>
			<div
				class="flex flex-col justify-between lg:justify-center gap-4 w-full lg:w-fit font-medium text-black *:text-base!"
			>
				<div class="flex justify-between">
					<p>MON - FRI:</p>
					<p class="font-medium">9:00 AM - 6:00 PM</p>
				</div>
				<div class="flex justify-between">
					<p>SAT - SUN:</p>
					<p class="font-medium">9:00 AM - 5:00 PM</p>
				</div>
				<p>
					Address: 123 Fairway Drive, Greenside Valley, Country
					Estates, UK
				</p>
				<p>Phone: +1 234 567 8910</p>
			</div>
		</article>
	</div>

	<hr class="mb-8 text-accent container" />

	<div
		class="flex flex-wrap justify-between items-center py-5 text-slate-200 *:text-sm! container"
	>
		<p class="mx-auto mb-5 md:mb-0 text-center">
			{new Date().getFullYear()} &copy; The Golf Club
		</p>

		<div class="flex justify-between gap-8 w-full md:w-fit">
			<a href="#">Privacy Policy</a>
			<a href="#">Terms & Conditions</a>
			<a href="#">Sitemap</a>
		</div>
	</div>
</footer>
