---

---

<div id="cursor" class="hidden z-999 fixed bg-accent rounded-full w-5 h-5">
</div>
<div
	id="cursor-blur"
	class="hidden z-999 fixed blur-3xl rounded-full w-20 h-20 bg-accent-dark"
>
</div>

<script>
	const cursor = document.querySelector("#cursor") as HTMLDivElement;
	const cursorBlur = document.querySelector("#cursor-blur") as HTMLDivElement;

	document.addEventListener("mousemove", (e) => {
		cursor.classList.remove("hidden");
		cursorBlur.classList.remove("hidden");

		cursor.style.left = e.x - cursor.offsetWidth / 2 + "px";
		cursor.style.top = e.y - cursor.offsetHeight / 2 + "px";

		cursorBlur.style.left = e.x - cursorBlur.offsetWidth / 2 + "px";
		cursorBlur.style.top = e.y - cursorBlur.offsetHeight / 2 + "px";
	});

	// const h4s = document.querySelectorAll("h4");

